<?xml version="1.0" encoding="UTF-8"?>

<!-- https://phpunit.readthedocs.io/en/latest/configuration.html -->
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="../../vendor/phpunit/phpunit/phpunit.xsd"
         backupGlobals="false"
         colors="true"
         cacheDirectory=".phpunit.cache"
>
    <php>
        <ini name="display_errors" value="1" />
        <ini name="error_reporting" value="1" />
        <server name="APP_ENV" value="test" force="true" />
        <server name="SHELL_VERBOSITY" value="1" />
    </php>

    <testsuites>
        <testsuite name="Actor Package Test Suite">
            <directory>../../packages/actor/tests</directory>
        </testsuite>
        <testsuite name="Clock Package Test Suite">
            <directory>../../packages/clock/tests</directory>
        </testsuite>
        <testsuite name="Domain Core Package Test Suite">
            <directory>../../packages/domain-core/tests</directory>
        </testsuite>
        <testsuite name="Event Dispatcher Package Test Suite">
            <directory>../../packages/event-dispatcher/tests</directory>
        </testsuite>
        <testsuite name="Graph Package Test Suite">
            <directory>../../packages/graph/tests</directory>
        </testsuite>
        <testsuite name="UUID Package Test Suite">
            <directory>../../packages/uuid/tests</directory>
        </testsuite>
    </testsuites>

    <source restrictNotices="true" restrictWarnings="true">
        <include>
            <directory>../../packages</directory>
        </include>
    </source>

    <extensions>
    </extensions>
</phpunit>
