#!/usr/bin/env php
<?php

declare(strict_types=1);

require __DIR__ . '/../vendor/autoload.php';

use PhpArchitecture\Parser\Infrastructure\Grammar\Registry\InMemoryGrammarRegistry;
use PhpArchitecture\Parser\Presentation\Controller\CLI\ViewGrammarCommand;
use PhpArchitecture\Parser\Presentation\Controller\CLI\ViewCompiledGrammarCommand;
use PhpArchitecture\Parser\Presentation\Controller\CLI\ViewAstDefinitionCommand;
use PhpArchitecture\Parser\Presentation\Controller\CLI\TokenizeCommand;
use PhpArchitecture\Parser\Presentation\Controller\CLI\GenerateTreeSchemaCommand;
use PhpArchitecture\Parser\Presentation\Controller\CLI\ParseCommand;
use PhpArchitecture\StateMachine\Infrastructure\Mapper\View\DefinitionViewMapper;
use PhpArchitecture\StateMachine\Infrastructure\Mapper\View\StateMachineViewMapper;
use PhpArchitecture\StateMachine\Infrastructure\Mapper\View\Strategy\DefinitionMappingStrategy;
use PhpArchitecture\StateMachine\Infrastructure\Mapper\View\Strategy\EdgeMappingStrategy;
use PhpArchitecture\StateMachine\Infrastructure\Mapper\View\Strategy\NodeMappingStrategy;
use PhpArchitecture\StateMachine\Infrastructure\Mapper\View\Strategy\StateMachineMappingStrategy;
use PhpArchitecture\StateMachine\Infrastructure\Mapper\View\Strategy\TransitionMappingStrategy;
use PhpArchitecture\StateMachine\Infrastructure\Mapper\View\Strategy\VertexMappingStrategy;
use PhpArchitecture\StateMachine\Presentation\Controller\CLI\PrintStateMachineCommand;
use Symfony\Component\Console\Application;

$registry = InMemoryGrammarRegistry::withBuiltIn();

$nodeMappingStrategy       = new NodeMappingStrategy();
$transitionMappingStrategy = new TransitionMappingStrategy();
$vertexMappingStrategy     = new VertexMappingStrategy();
$edgeMappingStrategy       = new EdgeMappingStrategy();

$stateMachineMapper = new StateMachineViewMapper([
    new StateMachineMappingStrategy(
        $nodeMappingStrategy,
        $transitionMappingStrategy,
        $vertexMappingStrategy,
        $edgeMappingStrategy,
    ),
]);

$application = new Application('PHP Architecture Kit', '1.0.0');

$application->addCommands([
    new ViewGrammarCommand($registry),
    new ViewCompiledGrammarCommand($registry),
    new ViewAstDefinitionCommand($registry),
    new TokenizeCommand($registry),
    new ParseCommand($registry),
    new GenerateTreeSchemaCommand($registry),
    new PrintStateMachineCommand($stateMachineMapper),
]);

$application->run();
