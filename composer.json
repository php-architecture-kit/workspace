{
    "name": "php-architecture-kit/workspace",
    "type": "project",
    "description": "Workspace for PHP Architecture Kit.",
    "keywords": [
        "php-architecture-kit",
        "workspace"
    ],
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "PhpArchitecture\\Parser\\": "packages/parser/src/",
            "PhpArchitecture\\Graph\\": "packages/graph/src/",
            "PhpArchitecture\\StateMachine\\": "packages/state-machine/src/",
            "PhpArchitecture\\Technical\\": "packages/technical/src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PhpArchitecture\\Actor\\Tests\\": "packages/actor/tests/",
            "PhpArchitecture\\Clock\\Tests\\": "packages/clock/tests/",
            "PhpArchitecture\\DomainCore\\Tests\\": "packages/domain-core/tests/",
            "PhpArchitecture\\Graph\\Tests\\": "packages/graph/tests/",
            "PhpArchitecture\\Uuid\\Tests\\": "packages/uuid/tests/",
            "Tests\\PhpArchitecture\\Parser\\": "packages/parser/tests/",
            "Benchmarks\\PhpArchitecture\\Uuid\\": "benchmarks/uuid/",
            "PhpArchitecture\\StateMachine\\Tests\\": "packages/state-machine/tests/"
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "packages/*",
            "options": {
                "symlink": true
            }
        }
    ],
    "require": {
        "php": "*",
        "psr/clock": "^1.0",
        "php-architecture-kit/actor": "@dev",
        "php-architecture-kit/clock": "@dev",
        "php-architecture-kit/domain-core": "@dev",
        "php-architecture-kit/uuid": "@dev",
        "php-architecture-kit/graph": "@dev",
        "php-architecture-kit/technical": "@dev",
        "php-architecture-kit/state-machine": "@dev"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "*",
        "phpmd/phpmd": "*",
        "phpstan/phpstan": "*",
        "phpunit/phpunit": "*",
        "symfony/uid": "^7.4",
        "ramsey/uuid": "^4.9",
        "phpbench/phpbench": "^1.4",
        "psr/event-dispatcher": "^1.0",
        "illuminate/events": "^12.53",
        "symfony/event-dispatcher": "^7.4",
        "symfony/console": "^7.4",
        "psr/container": "^2.0"
    },
    "scripts": {
        "benchmark:uuid": "vendor/bin/phpbench run benchmarks/uuid --config=tools/phpbench/phpbench.json --report=by_method",
        "code:fix": "vendor/bin/php-cs-fixer --config=tools/php-cs-fixer/php-cs-fixer.php fix",
        "code:fix:dry": "vendor/bin/php-cs-fixer --config=tools/php-cs-fixer/php-cs-fixer.php check --diff",
        "code:analyse": "vendor/bin/phpstan analyse packages/*/src -c tools/phpstan/phpstan.neon",
        "code:analyse:b": "vendor/bin/phpstan analyse packages -c tools/phpstan/phpstan.neon --generate-baseline tools/phpstan/baseline.neon --allow-empty-baseline",
        "phpunit": "bin/phpunit",
        "phpunit:coverage": [
            "@putenv XDEBUG_MODE=coverage",
            "@phpunit --do-not-cache-result --log-junit var/coverage/phpunit-report.xml --coverage-cobertura var/coverage/phpunit-coverage.xml --coverage-html var/coverage/html"
        ]
    }
}
